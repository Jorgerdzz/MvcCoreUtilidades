@{
}
@model List<Coche>
<h1>Coches Ajax Partial</h1>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>TIPO</th>
            <th>IMAGEN</th>
        </tr>
    </thead>
    <tbody>
        @foreach(Coche coche in Model)
        {
            <tr>
                <td>@coche.IdCoche</td>
                <td>@coche.Marca, @coche.Modelo</td>
                <td>
                    <img src="@coche.Imagen" style="width:40px; height:40px"/>
                </td>
            </tr>
        }
    </tbody>
</table>
